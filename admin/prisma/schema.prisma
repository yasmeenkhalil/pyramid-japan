generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
}

model Category {
  id        String      @id @default(cuid())
  nameEn    String
  nameAr    String
  nameJa    String
  slug      String      @unique
  imageUrl  String?
  sector    String
  machinery Machinery[]
  createdAt DateTime    @default(now())
}

// 1. إضافة جدول المصنعين (الماركات مثل كوماتسو، كوبهيلكو)
model Manufacturer {
  id        String      @id @default(cuid())
  name      String      @unique
  slug      String      @unique
  machinery Machinery[]
  createdAt DateTime    @default(now())
}

// 2. إضافة جدول تعريف أسماء المواصفات الفرعية (مثل وزن التشغيل، طول الذراع)
model Specification {
  id        String                   @id @default(cuid())
  nameEn    String
  nameAr    String
  nameJa    String
  slug      String                   @unique
  machinery MachinerySpecification[]
  createdAt DateTime                 @default(now())
}

model Unit {
  id        String                   @id @default(cuid())
  name      String                   @unique 
  machinery MachinerySpecification[]
  createdAt DateTime                 @default(now())
}

model MachinerySpecification {
  id              String        @id @default(cuid())
  machineryId     String
  machinery       Machinery     @relation(fields: [machineryId], references: [id], onDelete: Cascade)
  specificationId String
  specification   Specification @relation(fields: [specificationId], references: [id], onDelete: Cascade)
  value           String        
  unitId          String?
  unit            Unit?         @relation(fields: [unitId], references: [id], onDelete: SetNull)

  @@unique([machineryId, specificationId])
}


model Machinery {
  id              String                   @id @default(cuid())
  titleEn         String
  titleAr         String
  titleJa         String
  slug            String                   @unique
  stockNo         String?
  year            Int?
  hour            Int?
  price           Float?
  location        String
  sector          String                   
  minPrice        Float?                   
  avgPrice        Float?                   
  maxPrice        Float?                   
  descriptionEn   String?
  descriptionAr   String?
  descriptionJa   String?
  featured        Boolean                  @default(false)
  categoryId      String
  category        Category                 @relation(fields: [categoryId], references: [id])
  images          MachineryImage[]
  views           MachineryView[]
  manufacturerId  String
  manufacturer    Manufacturer             @relation(fields: [manufacturerId], references: [id])
  specifications  MachinerySpecification[]
  exportCountries MachineryExportCountry[]
  createdAt       DateTime                 @default(now())
}


model MachineryImage {
  id          String    @id @default(cuid())
  imageUrl    String
  machineryId String
  machinery   Machinery @relation(fields: [machineryId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
}

model Inquiry {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  country   String?
  message   String
  status    String   @default("pending")
  createdAt DateTime @default(now())
}

model MachineryView {
  id          String    @id @default(cuid())
  machineryId String
  machinery   Machinery @relation(fields: [machineryId], references: [id], onDelete: Cascade)
  ipAddress   String
  createdAt   DateTime  @default(now())

  @@index([machineryId, ipAddress])
}
model ExportCountry {
  id        String                 @id @default(cuid())
  nameEn    String                 @unique 
  nameAr    String                 @unique 
  nameJa    String                 @unique 
  slug      String                 @unique 
  machinery MachineryExportCountry[]
  createdAt DateTime               @default(now())
}

model MachineryExportCountry {
  id              String        @id @default(cuid())
  machineryId     String
  machinery       Machinery     @relation(fields: [machineryId], references: [id], onDelete: Cascade)
  exportCountryId String
  exportCountry   ExportCountry @relation(fields: [exportCountryId], references: [id], onDelete: Cascade)

  @@unique([machineryId, exportCountryId])
}
